{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    },
    {
      "src": "Resources/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/src/index.js"
    },
    {
      "source": "/Resources/(.*)",
      "destination": "/Resources/$1"
    },
    {
      "source": "/",
      "destination": "/frontend/html/Romana/index.html"
    },
    {
      "source": "/((?!api/|Resources/).*)",
      "destination": "/frontend/$1"
    }
  ]
}
